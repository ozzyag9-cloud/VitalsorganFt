{
  "name": "proof-of-life-protocol",
  "version": "0.1.0",
  "private": true,
  "description": "Privacy-preserving decentralized identity and proof-of-life protocol monorepo.",
  "workspaces": [
    "contracts",
    "frontend",
    "backend",
    "chain"
  ],
  "scripts": {
    "dev": "npm run dev --workspace frontend",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:backend": "npm run dev --workspace backend",
    "build": "npm run build --workspaces --if-present",
    "build:contracts": "npm run build --workspace contracts",
    "build:frontend": "npm run build --workspace frontend",
    "build:backend": "npm run build --workspace backend",
    "test": "npm run test --workspace contracts",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write .",
    "prepare": "husky",
    "dev:chain": "npm run dev --workspace chain",
    "build:chain": "npm run build --workspace chain"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
